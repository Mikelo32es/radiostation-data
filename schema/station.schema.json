{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RadioStation community catalog",
  "type": "object",
  "required": [
    "repoName",
    "community",
    "seedCount",
    "stations"
  ],
  "properties": {
    "repoName": {
      "type": "string"
    },
    "community": {
      "type": "string"
    },
    "seedSource": {
      "type": "string"
    },
    "seedCount": {
      "type": "integer"
    },
    "playableCount": {
      "type": "integer"
    },
    "verifiedCount": {
      "type": "integer"
    },
    "candidateCount": {
      "type": "integer"
    },
    "pendingCount": {
      "type": "integer"
    },
    "stations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "category",
          "community",
          "verificationStatus",
          "streams"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "community": {
            "type": "string"
          },
          "musicType": {
            "type": "string"
          },
          "websiteUrl": {
            "type": "string"
          },
          "logoUrl": {
            "type": "string"
          },
          "verificationStatus": {
            "enum": [
              "verified",
              "candidate",
              "seeded_pending"
            ]
          },
          "streams": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "label",
                "url"
              ],
              "properties": {
                "label": {
                  "type": "string"
                },
                "url": {
                  "type": "string"
                },
                "format": {
                  "type": "string"
                },
                "priority": {
                  "type": "integer"
                },
                "source": {
                  "type": "string"
                }
              }
            }
          },
          "aliasIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
