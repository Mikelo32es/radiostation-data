{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://radiostation/schema/home.schema.json",
  "title": "RadioStation home sections",
  "type": "object",
  "required": [
    "version",
    "sections"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "source"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "enum": [
              "ids",
              "featured",
              "trending",
              "recent",
              "query"
            ]
          },
          "stationIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 32
          },
          "query": {
            "type": "object",
            "properties": {
              "category": {
                "type": "string"
              },
              "community": {
                "type": "string"
              },
              "musicType": {
                "type": "string"
              },
              "verifiedOnly": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
